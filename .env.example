# Auto-filled by setup.sh — or fill manually:

# Public IP of this VPS
VPS_IP=1.2.3.4

# Random secret shared between backend and Coturn (min 32 chars)
# Generate with: openssl rand -hex 32
TURN_SECRET=replace_with_output_of_openssl_rand_hex_32

# Optional: custom domain for CORS (e.g. https://meets-abroad.duckdns.org)
# If not set, falls back to https://${VPS_IP}
DOMAIN=
